# Express Server Port
PORT=3001

# Gemini LLM API Key (Required for prompt routing & response compiling)
GEMINI_API_KEY=your_gemini_api_key_here

# Slack MCP Connection Configuration
# Choose transport type: "stdio" or "sse"
SLACK_MCP_TRANSPORT=stdio

# --- Option A: STDIO CONFIGURATION (App launches the MCP server dynamically) ---
# Command to execute (e.g., npx)
SLACK_MCP_COMMAND=npx
# Arguments separated by commas (e.g., -y,@modelcontextprotocol/server-slack)
SLACK_MCP_ARGS=-y,@modelcontextprotocol/server-slack

# Environment variables needed by the local Stdio MCP Slack server
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# --- Option B: SSE CONFIGURATION (App connects to an already running MCP server) ---
SLACK_MCP_SSE_URL=http://localhost:3010/sse
